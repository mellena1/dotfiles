{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ["@mellena1/opencode-auto-mode", {
      "model": { "id": "deepseek-v4-flash", "providerID": "opencode-go" }
    }]
  ],
  "permission": {
    "edit": "ask",
    "bash": {
      "ls*": "allow",
      "find*": "allow",
      "mkdir*": "allow",
      "cat*": "allow",
      "pwd": "allow",
      "echo*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "grep*": "allow",
      "rg*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "which*": "allow",
      "cd *": "allow",
      "wc*": "allow",
      "sort*": "allow",
      "uniq*": "allow",
      "diff*": "allow",
      "file*": "allow",
      "*": "ask"
    }
  }
}
